APP_URL=https://velxo.shop
API_URL=https://api.velxo.shop
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_API_URL=https://api.velxo.shop
PORT=3001
CORS_ORIGIN=https://velxo.shop,http://localhost:3000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgres://postgres:[password]@[host]:5432/postgres
# FIX #24: DIRECT_URL is required by Prisma when using Supabase connection pooling.
# Set it to the direct (non-pooled) Supabase connection string.
DIRECT_URL=postgres://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
JWT_SECRET=your-production-jwt-secret

# ── Backblaze B2 Storage ─────────────────────────────────────────────────────
# Bucket is PRIVATE — objects are accessed via presigned URLs, not public links
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005
B2_BUCKET=velxo-assets
B2_KEY_ID=your-b2-application-key-id
B2_APP_KEY=your-b2-application-key
# How long presigned URLs stay valid in seconds
# Public images (listings, avatars, gigs): 86400 = 24 hours
# KYC docs are always signed at 3600s (1 hour) regardless of this value
B2_URL_TTL_SECONDS=86400
JWT_EXPIRES_IN=7d
ADMIN_PASSWORD=your-strong-admin-password-here
FLUTTERWAVE_PUBLIC_KEY=your-flutterwave-public-key
FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key
FLUTTERWAVE_WEBHOOK_SECRET=your-flutterwave-webhook-secret
PAYMENT_IO_API_URL=https://api.paymento.io/v1
PAYMENT_IO_API_KEY=your-payment-io-api-key
PAYMENT_IO_SECRET_KEY=your-payment-io-secret-key
PAYMENT_IO_IPN_URL=https://velxo.onrender.com/api/v1/payments/webhook/paymentio
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@velxo.shop
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
FRONTEND_URL=https://market.velxo.shop
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://api.velxo.shop/api/v1/auth/google/callback
