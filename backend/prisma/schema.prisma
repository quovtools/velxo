generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  BUYER
  SELLER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum ListingStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  SUSPENDED
  SOLD
  EXPIRED
}

enum OrderStatus {
  PENDING
  PAID
  IN_PROGRESS
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
  DISPUTED
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  FLUTTERWAVE      // African payments (Nigeria, Ghana, Kenya, etc.)
  PAYSTACK         // African payments (Nigeria-focused)
  MOMO_MTN         // Mobile Money - MTN (20+ African countries)
  MOMO_AIRTEL      // Mobile Money - Airtel (16+ African countries)
  MOMO_VODAFONE    // Mobile Money - Vodafone (Ghana, etc.)
  PAYMENT_IO       // Paymento / Payment.io (crypto & card)
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_BUYER
  RESOLVED_SELLER
  RESOLVED_PLATFORM
  CLOSED
}

enum DisputeResolutionType {
  REFUND_BUYER
  RELEASE_TO_SELLER
  SPLIT
  OTHER
}

enum MessageSenderType {
  BUYER
  SELLER
  ADMIN
  SUPPORT
  SYSTEM
}

enum NotificationType {
  ORDER_STATUS
  MESSAGE
  DISPUTE
  WITHDRAWAL
  LISTING_APPROVED
  LISTING_REJECTED
  KYC_APPROVED
  KYC_REJECTED
  FRAUD_ALERT
  SYSTEM
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketCategory {
  PAYMENT
  DELIVERY
  ACCOUNT
  DISPUTE
  OTHER
}

enum FraudFlagType {
  SUSPICIOUS_LOGIN
  RAPID_ORDERS
  HIGH_VALUE_TRANSACTION
  MULTIPLE_ACCOUNTS
  CHARGEBACK_RISK
  MANUAL_REVIEW
}

enum FraudFlagSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  PAYMENT
  REFUND
  ESCROW_RELEASE
  WITHDRAWAL
  ROLE_CHANGE
  VERIFICATION_CHANGE
}

enum CommissionStatus {
  PENDING
  PAID
}

model users {
  id               String   @id @default(cuid())
  email            String   @unique
  emailVerified    Boolean  @default(false)
  phone            String?
  phoneVerified    Boolean  @default(false)
  passwordHash     String?
  firstName        String?
  lastName         String?
  avatarUrl        String?
  role             Role     @default(BUYER)
  notificationPreferences Json?
  preferences      Json?
  isActive         Boolean  @default(true)
  isBanned         Boolean  @default(false)
  banReason        String?
  lastLoginAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  sellers          sellers?
  buyerOrders      orders[] @relation("OrderBuyer")
  buyerReviews     reviews[] @relation("ReviewBuyer")
  initiatedDisputes disputes[] @relation("DisputeInitiator")
  resolvedDisputes  disputes[] @relation("DisputeResolver")
  messages         messages[]
  supportTickets   supportTickets[]
  adminAuditLogs   adminAuditLogs[] @relation("AdminAuditLogActor")
  fraudFlags       fraudFlags[]
  notifications    notifications[]
  paymentMethods   paymentMethods[]
  wallet           wallet?
  affiliateReferrals  affiliateReferrals[] @relation("AffiliateReferrer")
  affiliateReferred   affiliateReferrals?  @relation("AffiliateReferred")
  velxoCoins          velxoCoins?
  rewardRedemptions   rewardRedemptions[]

  @@index([email])
  @@index([role])
  @@index([createdAt])
  @@map("users")
}

enum SellerAccountType {
  STANDARD
  BOOSTER
  BOTH
}

model sellers {
  id              String   @id @default(cuid())
  userId          String   @unique
  storeName       String
  storeDescription String?
  accountType     SellerAccountType @default(STANDARD)
  storeSlug       String?  @unique
  isVerified      Boolean  @default(false)
  verificationDocuments Json?
  kycStatus       String   @default("NOT_SUBMITTED") // NOT_SUBMITTED | SUBMITTED | APPROVED | REJECTED
  kycIdType       String?
  kycFullName     String?
  kycDocumentNumber String?
  kycIdImageUrl   String?
  kycSelfieImageUrl String?
  kycSubmittedAt  DateTime?
  kycReviewedAt   DateTime?
  kycRejectionReason String?
  reputationScore Float    @default(0.0)
  totalSales      Int      @default(0)
  totalRevenue    Decimal  @default(0) @db.Decimal(12, 2)
  averageRating   Float    @default(0.0)
  responseRate    Float    @default(0.0)
  responseTime    Int?
  subscriptionTier String @default("FREE")
  subscriptionEndsAt DateTime?
  featuredUntil    DateTime?
  isSuspended     Boolean  @default(false)
  suspensionReason String?
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            users           @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings        listings[]
  orders          orders[]        @relation("SellerOrders")
  reviews          reviews[]       @relation("ReviewSeller")
  commissions     commissions[]
  gigs            gigs[]
  withdrawalRequests withdrawalRequests[]
  subscriptions   sellerSubscriptions[]

  @@index([userId])
  @@index([isVerified])
  @@index([kycStatus])
  @@index([reputationScore])
  @@index([totalSales])
  @@map("sellers")
}

model sellerSubscriptions {
  id          String   @id @default(cuid())
  sellerId    String
  plan        String // PRO | PREMIUM
  status      String   @default("PENDING") // PENDING | ACTIVE | CANCELLED | EXPIRED
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("NGN")
  provider    String // PAYMENT_IO | FLUTTERWAVE
  providerRef String? // payment token / reference returned by the gateway
  startsAt    DateTime?
  endsAt      DateTime?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seller      sellers  @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([status])
  @@map("seller_subscriptions")
}

model categories {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  imageUrl    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subcategories subcategories[]
  listings      listings[]

  @@index([slug])
  @@index([sortOrder])
  @@map("categories")
}

model subcategories {
  id          String   @id @default(cuid())
  categoryId  String
  name        String
  slug        String
  description String?
  icon        String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    categories   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  listings    listings[]

  @@unique([categoryId, slug])
  @@index([categoryId])
  @@map("subcategories")
}

model listings {
  id             String        @id @default(cuid())
  sellerId       String
  categoryId     String
  subcategoryId  String?
  title          String
  description    String
  price          Decimal       @db.Decimal(12, 2)
  currency       String        @default("NGN")
  gameId         String?
  gameName       String
  sku            String?

  status         ListingStatus @default(DRAFT)

  rank           String?
  level          Int?
  skins          Json? // [{name, imageUrl, rarity}]
  inventory      Json?
  linkedAccounts Json?
  loginMethod    String?
  region         String?
  platform       String?

  playerId       String?
  playerUid      String?
  deliveryTime   Int? // minutes

  images         String[]
  videos         String[]
  screenshots    String[]

  isFeatured     Boolean       @default(false)
  isSponsored    Boolean       @default(false)
  isSold         Boolean       @default(false)
  viewCount      Int           @default(0)
  salesCount     Int           @default(0)

  moderationNotes String?
  moderatedAt    DateTime?
  moderatedBy    String?

  searchVector   Unsupported("tsvector")?
  metadata       Json?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  expiresAt      DateTime?

  category       categories      @relation(fields: [categoryId], references: [id])
  subcategory    subcategories?  @relation(fields: [subcategoryId], references: [id])
  seller         sellers         @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orderItems     orderItems[]
  listingReviews reviews[]        @relation("ListingReviews")
  fraudFlags     fraudFlags[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([status])
  @@index([price])
  @@index([gameName])
  @@index([region])
  @@index([platform])
  @@index([isFeatured])
  @@index([createdAt])
  @@map("listings")
}

model orders {
  id              String      @id @default(cuid())
  orderNumber     String      @unique @default(cuid())
  buyerId         String
  sellerId        String?

  status          OrderStatus @default(PENDING)

  subtotal        Decimal     @db.Decimal(12, 2)
  taxAmount       Decimal     @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal     @db.Decimal(12, 2)
  commissionRate  Decimal     @default(0.10) @db.Decimal(5, 4)
  commissionAmount Decimal    @db.Decimal(12, 2)
  sellerPayout    Decimal     @db.Decimal(12, 2)

  currency        String      @default("USD")

  buyerNote       String?
  sellerNote      String?
  deliveryData    Json?

  paidAt          DateTime?
  deliveredAt     DateTime?
  acceptedAt      DateTime?
  sellerDeliverDeadline DateTime?
  buyerConfirmDeadline DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  refundedAt      DateTime?

  metadata        Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  buyer           users            @relation("OrderBuyer", fields: [buyerId], references: [id])
  seller          sellers?         @relation("SellerOrders", fields: [sellerId], references: [id])
  escrow          escrowTransactions?
  orderItems      orderItems[]
  disputes        disputes[]
  payments        payments[]
  orderReviews    reviews[]        @relation("OrderReviews")
  commissions     commissions[]
  orderFraudFlags fraudFlags[]    @relation("OrderFraudFlags")

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([orderNumber])
  @@index([createdAt])
  @@map("orders")
}

model orderItems {
  id           String   @id @default(cuid())
  orderId      String
  listingId    String?
  quantity     Int      @default(1)
  unitPrice    Decimal  @db.Decimal(12, 2)
  totalPrice   Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())

  order        orders    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listing      listings? @relation(fields: [listingId], references: [id])

  @@index([orderId])
  @@index([listingId])
  @@map("order_items")
}

enum GigStatus {
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  SUSPENDED
  COMPLETED
}

model marqueeItems {
  id          String   @id @default(cuid())
  text        String
  linkHref    String?
  linkText    String?
  icon        String?
  color       String?  @default("brand")
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("marquee_items")
}

model topupProducts {
  id            String   @id @default(cuid())
  gameName      String
  gameSlug      String?
  title         String
  description   String?
  price         Decimal  @db.Decimal(12, 2)
  currency      String   @default("USD")
  imageUrl      String?
  region        String?  @default("Global")
  deliveryInfo  String?
  stock         Int?     @default(-1)
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@index([gameName])
  @@map("topup_products")
}

model gigs {
  id            String      @id @default(cuid())
  sellerId      String
  title         String
  description   String
  gameName      String
  rankFrom      String?
  rankTo        String?
  platform      String?
  region        String?
  accountType   String?     @default("RANK_BOOST")
  price         Decimal     @db.Decimal(12, 2)
  currency      String      @default("USD")
  deliveryTime  Int?
  imageUrl      String?
  isActive      Boolean     @default(true)
  status        GigStatus   @default(PENDING_APPROVAL)
  rejectionReason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  seller        sellers     @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([status, isActive])
  @@index([gameName])
  @@map("gigs")
}

model escrowTransactions {
  id              String       @id @default(cuid())
  orderId         String       @unique
  status          EscrowStatus @default(HELD)
  amount          Decimal      @db.Decimal(12, 2)
  currency        String       @default("USD")
  releasedAt      DateTime?
  refundedAt      DateTime?
  disputedAt      DateTime?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order           orders       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@map("escrow_transactions")
}

model wallet {
  id            String   @id @default(cuid())
  userId        String   @unique
  balance       Decimal  @default(0) @db.Decimal(12, 2)
  currency      String   @default("USD")
  lockedBalance Decimal  @default(0) @db.Decimal(12, 2)
  totalEarnings Decimal  @default(0) @db.Decimal(12, 2)
  totalWithdrawn Decimal @default(0) @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          users                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  walletTransactions[] @relation("WalletTransactions")

  @@index([userId])
  @@map("wallets")
}

model walletTransactions {
  id          String   @id @default(cuid())
  walletId    String
  type        String // CREDIT, DEBIT, HOLD, RELEASE, FEE, REFUND
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  balanceAfter Decimal @db.Decimal(12, 2)
  description String
  relatedId   String? // orderId, withdrawalId, etc.
  metadata    Json?
  createdAt   DateTime @default(now())

  walletRelation wallet @relation("WalletTransactions", fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([createdAt])
  @@map("wallet_transactions")
}

model reviews {
  id          String   @id @default(cuid())
  orderId     String
  listingId   String
  buyerId     String
  sellerId    String
  rating      Int
  comment     String
  isEdited    Boolean  @default(false)
  isHidden    Boolean  @default(false)
  helpfulCount Int     @default(0)
  sellerResponse String?
  sellerRespondedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order       orders    @relation("OrderReviews", fields: [orderId], references: [id], onDelete: Cascade)
  buyer       users     @relation("ReviewBuyer", fields: [buyerId], references: [id])
  seller      sellers   @relation("ReviewSeller", fields: [sellerId], references: [id])
  listing     listings  @relation("ListingReviews", fields: [listingId], references: [id])

  @@index([sellerId])
  @@index([listingId])
  @@index([rating])
  @@index([createdAt])
  @@map("reviews")
}

model conversations {
  id             String   @id @default(cuid())
  buyerId        String
  sellerId       String
  orderId        String?
  isBlocked      Boolean  @default(false)
  lastMessageAt  DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  messages       messages[]

  @@index([buyerId, sellerId])
  @@map("conversations")
}

model messages {
  id              String               @id @default(cuid())
  conversationId  String
  senderId        String
  senderType      MessageSenderType    @default(BUYER)
  content         String
  attachments     String[]
  isRead          Boolean              @default(false)
  readAt          DateTime?
  isDeleted       Boolean              @default(false)
  metadata        Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  conversation    conversations @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          users         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([isRead])
  @@index([createdAt])
  @@map("messages")
}

model notifications {
  id        String            @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean           @default(false)
  readAt    DateTime?
  createdAt DateTime          @default(now())

  user      users             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model disputes {
  id              String           @id @default(cuid())
  orderId         String
  initiatedById   String
  status          DisputeStatus    @default(OPEN)
  reason          String
  evidence        Json?
  resolutionType  DisputeResolutionType?
  resolutionNotes String?
  refundAmount    Decimal?         @db.Decimal(12, 2)
  resolvedBy      String?
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order           orders                @relation(fields: [orderId], references: [id])
  initiator       users                 @relation("DisputeInitiator", fields: [initiatedById], references: [id])
  resolver        users?                @relation("DisputeResolver", fields: [resolvedBy], references: [id])
  messages        disputeMessages[]

  @@index([orderId])
  @@index([status])
  @@index([createdAt])
  @@map("disputes")
}

model disputeMessages {
  id         String   @id @default(cuid())
  disputeId  String
  senderId   String
  content    String
  attachments String[]
  isSystem   Boolean  @default(false)
  createdAt  DateTime @default(now())

  dispute    disputes @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@map("dispute_messages")
}

model supportTickets {
  id          String              @id @default(cuid())
  userId      String
  subject     String
  category    SupportTicketCategory
  priority    String              @default("MEDIUM")
  status      SupportTicketStatus @default(OPEN)
  assigneeId  String?
  tags        String[]
  metadata    Json?
  closedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        users               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@map("support_tickets")
}

model adminAuditLogs {
  id          String        @id @default(cuid())
  actorId     String
  action      AuditAction
  entityType  String
  entityId    String
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  actor       users @relation("AdminAuditLogActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

model fraudFlags {
  id           String             @id @default(cuid())
  userId       String
  listingId    String?
  orderId      String?
  type         FraudFlagType
  severity     FraudFlagSeverity
  status       String             @default("OPEN")
  score        Float?
  details      Json?
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime @default(now())

  user         users              @relation(fields: [userId], references: [id])
  listing      listings?          @relation(fields: [listingId], references: [id])
  order        orders?            @relation("OrderFraudFlags", fields: [orderId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
  @@map("fraud_flags")
}

model paymentMethods {
  id           String   @id @default(cuid())
  userId       String
  provider     PaymentProvider
  type         String   // card, bank, wallet, crypto
  last4        String?
  brand        String?
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         users              @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments     payments[]

  @@index([userId])
  @@map("payment_methods")
}

model payments {
  id           String         @id @default(cuid())
  orderId      String
  methodId     String?
  provider     PaymentProvider
  status       PaymentStatus  @default(PENDING)
  amount       Decimal        @db.Decimal(12, 2)
  currency     String         @default("USD")
  providerTransactionId String?
  metadata     Json?
  errorMessage String?
  paidAt       DateTime?
  refundedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  order        orders          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method       paymentMethods? @relation(fields: [methodId], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([providerTransactionId])
  @@map("payments")
}

model withdrawalRequests {
  id           String            @id @default(cuid())
  sellerId     String
  amount       Decimal           @db.Decimal(12, 2)
  currency     String            @default("USD")
  status       WithdrawalStatus  @default(PENDING)
  method       String            // bank, crypto, other
  destination  Json
  fee          Decimal           @default(0) @db.Decimal(12, 2)
  netAmount    Decimal           @db.Decimal(12, 2)
  processedBy  String?
  notes        String?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  seller       sellers           @relation(fields: [sellerId], references: [id])

  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@map("withdrawal_requests")
}

model commissions {
  id          String   @id @default(cuid())
  orderId     String
  sellerId    String
  rate        Decimal  @db.Decimal(5, 4)
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  status      CommissionStatus @default(PENDING)
  paidAt      DateTime?
  dueAt       DateTime?
  createdAt   DateTime @default(now())

  order       orders   @relation(fields: [orderId], references: [id])
  seller      sellers  @relation(fields: [sellerId], references: [id])

  @@index([sellerId, status])
  @@map("commissions")
}

model gameSlides {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  imageUrl    String
  linkHref    String?
  badge       String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("game_slides")
}

model blogPosts {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  category    String   @default("Platform")
  author      String   @default("Velxo Team")
  coverImage  String?
  isPublished Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  readTime    String?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, isFeatured])
  @@index([slug])
  @@index([category])
  @@index([publishedAt])
  @@map("blog_posts")
}

model affiliateReferrals {
  id              String   @id @default(cuid())
  referrerId      String
  referredUserId  String?  @unique
  referralCode    String   @unique
  status          String   @default("PENDING")
  commissionRate  Decimal  @default(0.02) @db.Decimal(5, 4)
  totalEarned     Decimal  @default(0) @db.Decimal(12, 2)
  totalPaid       Decimal  @default(0) @db.Decimal(12, 2)
  clickCount      Int      @default(0)
  signupCount     Int      @default(0)
  tradeCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  referrer        users    @relation("AffiliateReferrer", fields: [referrerId], references: [id])
  referredUser    users?   @relation("AffiliateReferred", fields: [referredUserId], references: [id])

  @@index([referrerId])
  @@index([referralCode])
  @@index([status])
  @@map("affiliate_referrals")
}

model velxoCoins {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  currency  String   @default("VXC")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      users               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions rewardCoinTransactions[] @relation("RewardCoinTransactions")

  @@index([userId])
  @@map("velxo_coins")
}

model rewardCoinTransactions {
  id          String   @id @default(cuid())
  coinId      String
  type        String   // CREDIT, DEBIT, BONUS, REFERRAL, PURCHASE, SALE, REVIEW
  amount      Int
  balanceAfter Int
  description String
  relatedId   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  coin        velxoCoins @relation("RewardCoinTransactions", fields: [coinId], references: [id], onDelete: Cascade)

  @@index([coinId])
  @@index([createdAt])
  @@map("reward_coin_transactions")
}

model rewardCatalog {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // GIFT_CARD, TOP_UP, ITEM, COUPON
  coinCost    Int
  imageUrl    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  redemptions rewardRedemptions[]

  @@index([isActive, sortOrder])
  @@map("reward_catalog")
}

model rewardRedemptions {
  id          String   @id @default(cuid())
  userId      String
  catalogId   String
  coinCost    Int
  status      String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  metadata    Json?
  processedBy String?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        users         @relation(fields: [userId], references: [id])
  catalogItem rewardCatalog @relation(fields: [catalogId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("reward_redemptions")
}
